{
  "name": "elizabethannstein",
  "version": "1.0.0",
  "private": false,
  "description": "Elizabeth Stein's interactive 3D galaxy portfolio — projects across 6 galaxies",
  "author": "Elizabeth Stein",
  "license": "MIT",
  "packageManager": "pnpm@10.26.2",
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build",
    "start": "next start",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test --project=smoke",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ci": "playwright test --project=smoke --project=visual --project=chromium --project=firefox --project=webkit --project=mobile-chrome --project=mobile-safari",
    "test:e2e:visual": "playwright test --project=visual",
    "analyze": "ANALYZE=true next build",
    "biome:check": "biome check .",
    "biome:fix": "biome check . --write",
    "biome:format": "biome format . --write",
    "test:coverage": "vitest run --coverage",
    "screenshots": "tsx scripts/capture-screenshots.ts"
  },
  "dependencies": {
    "@arcjet/next": "^1.4.0",
    "@gsap/react": "^2.1.2",
