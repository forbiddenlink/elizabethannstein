# Copy to .env.local for local development. Set these in Vercel Project Settings for production.

# Public site URL (canonical links, sitemap, OG metadata)
NEXT_PUBLIC_SITE_URL=https://elizabethannstein.com

# Optional: Google Analytics measurement ID
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Optional: Sentry error reporting (production only when DSN is set)
# NEXT_PUBLIC_SENTRY_DSN=

# Galaxy Guide AI (MiniMax) — server-only; never expose to the client
# MINMAX_API_KEY=

# Contact form via Resend — server-only
# RESEND_API_KEY=
# Optional override for where contact mail is delivered (defaults in code if unset)
# CONTACT_FORWARD_TO=you@example.com

# Arcjet — abuse protection for /api/* (recommended in production)
# ARCJET_KEY=

# Local E2E / Playwright (optional)
# PLAYWRIGHT_PORT=3100
# BASE_URL=http://127.0.0.1:3100
# CI runs: pnpm build && pnpm test:e2e:ci (production server on 3100). Visual snapshot tests: pnpm exec playwright install && pnpm exec playwright test --project=visual

# Bundle analysis (optional)
# ANALYZE=true
